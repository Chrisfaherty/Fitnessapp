      "dataAttribute": "biceps",
      "label": "Biceps"
    },
    "triceps": {
      "view": "back",
      "dataAttribute": "triceps",
      "label": "Triceps"
    },
    "forearms": {
      "view": "front",
      "dataAttribute": "forearms",
      "label": "Forearms"
    },
    "lats": {
      "view": "back",
      "dataAttribute": "lats",
      "label": "Lats"
    },
    "middle back": {
      "view": "back",
      "dataAttribute": "middle back",
      "label": "Middle Back"
    },
    "lower back": {
      "view": "back",
      "dataAttribute": "lower back",
