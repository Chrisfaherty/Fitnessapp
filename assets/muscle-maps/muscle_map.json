      "label": "Hamstrings"
    },
    "calves": {
      "view": "both",
      "dataAttribute": "calves",
      "label": "Calves"
    },
    "hip flexors": {
      "view": "front",
      "dataAttribute": "hip flexors",
      "label": "Hip Flexors"
    },
    "adductors": {
      "view": "front",
      "dataAttribute": "adductors",
